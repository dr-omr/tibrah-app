    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "cross-env": "^10.1.0",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.33",
    "identity-obj-proxy": "^3.0.0",
