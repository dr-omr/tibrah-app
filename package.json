    "framer-motion": "^12.23.26",
    "fuse.js": "^7.2.0",
    "groq-sdk": "^0.37.0",
    "jose": "^6.2.2",
    "localforage": "^1.10.0",
    "lucide-react": "^0.294.0",
    "next": "14.2.33",
    "next-pwa": "^5.6.0",
    "nodemailer": "^8.0.5",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.2.0",
