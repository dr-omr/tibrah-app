{
  "name": "tibrah",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NODE_OPTIONS=--max_old_space_size=4096 node node_modules/next/dist/bin/next build",
    "build:mobile": "cross-env BUILD_MODE=mobile next build",
    "build:native": "node build-native.js",
    "build:native:open": "node build-native.js --open",
    "build:ios": "node build-native.js --ios --open",
    "build:all": "node build-native.js --all",
    "start": "next start",
    "cap:sync": "npx cap sync",
    "analyze": "ANALYZE=true next build",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:tayyibat": "jest lib/tayyibat/__tests__/tayyibat-integration.test.ts --no-coverage --verbose",
    "verify:tayyibat": "npx tsx lib/tayyibat/__tests__/verify-tayyibat-integration.ts",
    "verify:assessment": "npx tsx lib/assessment/__tests__/verify-assessment-lifecycle.ts",
    "verify:result-model": "npx tsx lib/result-engine/__tests__/verify-result-model.ts",
    "verify:adaptive": "npx tsx lib/health-engine/__tests__/verify-adaptive-question-orchestrator.ts",
    "verify:confidence": "npx tsx lib/health-engine/__tests__/verify-confidence-triage.ts",
    "verify:director": "npx tsx lib/assessment/__tests__/verify-assessment-director.ts",
    "verify:result-story": "npx tsx lib/result-engine/__tests__/verify-result-story.ts",
    "verify:questions": "npx tsx lib/assessment/__tests__/verify-question-experience.ts",
    "verify:nutrition-protocols": "npx tsx lib/tayyibat/__tests__/verify-nutrition-protocols.ts"
  },
