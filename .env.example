# ═══════════════════════════════════════════════════════
# Tibrah Platform — Environment Variables
# ═══════════════════════════════════════════════════════

# ─── AI Services ───────────────────────────────────────
# Google Gemini AI (server-side only — NOT NEXT_PUBLIC_)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq AI Fallback (server-side only — NOT NEXT_PUBLIC_)
GROQ_API_KEY=your_groq_api_key_here

# ─── Firebase Client SDK ──────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-app.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Firebase Admin SDK (REQUIRED for session verification) ───
# Base64-encoded service account JSON
FIREBASE_SERVICE_ACCOUNT_KEY=

# ─── Session Security (REQUIRED for production) ──────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# ─── Admin Security (REQUIRED for production) ────────
ADMIN_PASSCODE=your_secure_admin_passcode
ADMIN_API_SECRET=your_long_random_secret_key

# Server-only admin emails (comma-separated, NOT NEXT_PUBLIC_)
ADMIN_EMAILS=dr.omar@tibrah.com

# ─── Web Push Notifications ──────────────────────────
# Generate VAPID keys with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_KEY=

# ─── App Config ──────────────────────────────────────
NEXT_PUBLIC_APP_NAME=طِبرَا
NEXT_PUBLIC_WHATSAPP_NUMBER=967771447111
NEXT_PUBLIC_BASE_URL=https://tibrah.com
